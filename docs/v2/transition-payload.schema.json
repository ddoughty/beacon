{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beacon.local/schemas/transition-payload.schema.json",
  "title": "Beacon Transition Ingestion Payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sent_at",
    "transitions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "client_event_id",
          "occurred_at",
          "signal_type",
          "latitude",
          "longitude",
          "horizontal_accuracy_m"
        ],
        "properties": {
          "client_event_id": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-7[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
          },
          "occurred_at": {
            "type": "string",
            "format": "date-time"
          },
          "signal_type": {
            "type": "string",
            "enum": [
              "visit_arrival",
              "visit_departure",
              "significant_location_change",
              "manual_correction"
            ]
          },
          "latitude": {
            "type": "number",
            "minimum": -90,
            "maximum": 90
          },
          "longitude": {
            "type": "number",
            "minimum": -180,
            "maximum": 180
          },
          "horizontal_accuracy_m": {
            "type": "number",
            "minimum": 0
          },
          "vertical_accuracy_m": {
            "type": "number",
            "minimum": 0
          },
          "altitude_m": {
            "type": "number"
          },
          "speed_mps": {
            "type": "number",
            "minimum": 0
          },
          "course_deg": {
            "type": "number",
            "minimum": 0,
            "maximum": 360
          },
          "device_time_zone": {
            "type": "string",
            "minLength": 1
          },
          "motion_activity": {
            "type": "string",
            "enum": [
              "stationary",
              "walking",
              "running",
              "cycling",
              "automotive",
              "unknown"
            ]
          },
          "is_mocked": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
